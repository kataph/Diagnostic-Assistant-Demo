<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.example.org/zorro/"
         xmlns="http://www.example.org/zorro/">

<owl:Ontology rdf:about="http://www.example.org/zorro">
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This ontology has been developed by Ameneh Naghdi Pour and colleagues (1). See also https://github.com/kai-vu/zorro where a serialization is present. 

Since the development of such ontology is still ongoing, we (Compagno Francesco) wrote this file to reflect our understanding of the latest (unpublished) version of the ontology after discussion with the authors. 

We apported also modifications:
- addition of :monitors object property
- deletion of Cause class
- addition of inverseOf axiom between hasCause and hasEffect
- replaced RepairAction and Test with a small taxonomy of DiagnosticActions
- addition of hasSuperComponent proprty inverse of hasSubComponent





(1) POUR, Ameneh Naghdi, et al. Knowledge Representation and Engineering for Smart Diagnosis of Cyber Physical Systems. In: ISWC 2024 Posters, Demos and Industry Tracks: From Novel Ideas to Industrial Practice, ISWC-Posters-Demos-Industry 2024. CEUR, 2024. p. 1-3.</rdfs:comment>
</owl:Ontology>

<owl:ObjectProperty rdf:about="hasSubFunction">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <rdfs:domain rdf:resource="Function"/>
  <rdfs:range rdf:resource="Function"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#topObjectProperty">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>
  <owl:inverseOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="failsVia">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <rdfs:domain rdf:resource="Component"/>
  <rdfs:range rdf:resource="Problem"/>
  <owl:propertyChainAxiom>
    <rdf:Description>
      <rdf:first rdf:resource="hasFunction"/>
      <rdf:rest>
        <rdf:Description>
          <rdf:first rdf:resource="defines"/>
          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </owl:propertyChainAxiom>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="dependsOn">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <rdfs:domain rdf:resource="Function"/>
  <rdfs:range rdf:resource="Function"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Input-dependency between functions:
X dependsOn Y if X makes use of (part of) the output of Y.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="defines">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <rdfs:domain rdf:resource="Function"/>
  <rdfs:range rdf:resource="Problem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasFunction">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <rdfs:domain rdf:resource="Component"/>
  <rdfs:range rdf:resource="Function"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasEffect">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <rdfs:domain rdf:resource="Problem"/>
  <rdfs:range rdf:resource="Problem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="monitors">
  <rdfs:subPropertyOf rdf:resource="dependsOn"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">X monitors Y iff X makes use of (part of) the output of Y to provide information about Y.
We introduced this relation to clarify certain diagnostic reasoning methods that exploit functional dependencies.</rdfs:comment>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasTest">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <rdfs:domain rdf:resource="Problem"/>
  <rdfs:range rdf:resource="DiagnosticAction"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasCause">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <owl:inverseOf rdf:resource="hasEffect"/>
  <rdfs:domain rdf:resource="Problem"/>
  <rdfs:range rdf:resource="Problem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasRepairAction">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <rdfs:domain rdf:resource="Problem"/>
  <rdfs:range rdf:resource="DiagnosticAction"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasSubComponent">
  <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
  <owl:inverseOf rdf:resource="hasSuperComponent"/>
  <rdfs:domain rdf:resource="Component"/>
  <rdfs:range rdf:resource="Component"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="hasSuperComponent"/>

<owl:DatatypeProperty rdf:about="hasCost">
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="Function">
  <owl:disjointWith rdf:resource="Problem"/>
</owl:Class>

<owl:Class rdf:about="DiagnosticAction">
  <owl:disjointWith rdf:resource="Effect"/>
  <owl:disjointWith rdf:resource="Function"/>
  <owl:disjointWith rdf:resource="Problem"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Any action that service personnel may perform on a component while addressing an equipment failure.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="Effect">
  <owl:disjointWith rdf:resource="Function"/>
  <owl:disjointWith rdf:resource="Problem"/>
</owl:Class>

<owl:Class rdf:about="Problem"/>

<owl:Class rdf:about="Replace">
  <rdfs:subClassOf rdf:resource="DiagnosticAction"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="hasCost"/>
      <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</owl:hasValue>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swapping a component with another component.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="Adjust">
  <rdfs:subClassOf rdf:resource="DiagnosticAction"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="hasCost"/>
      <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</owl:hasValue>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adjusting, refitting, tuning, reconfiguring, or repairing a component without replacing it.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="Component">
  <owl:disjointWith rdf:resource="DiagnosticAction"/>
  <owl:disjointWith rdf:resource="Effect"/>
  <owl:disjointWith rdf:resource="Function"/>
  <owl:disjointWith rdf:resource="Problem"/>
</owl:Class>

<owl:Class rdf:about="Test">
  <rdfs:subClassOf rdf:resource="DiagnosticAction"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="hasCost"/>
      <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</owl:hasValue>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Testing or measuring a component using tools and/or by actively manipulating it.</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="Observe">
  <rdfs:subClassOf rdf:resource="DiagnosticAction"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="hasCost"/>
      <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</owl:hasValue>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Visually inspecting or analyzing a component without tools and without physically manipulating it.</rdfs:comment>
</owl:Class>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="Adjust"/>
    <rdf:Description rdf:about="Observe"/>
    <rdf:Description rdf:about="Replace"/>
    <rdf:Description rdf:about="Test"/>
  </owl:members>
</owl:AllDisjointClasses>


</rdf:RDF>
